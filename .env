DATABASE_URL=postgresql+psycopg2://letstry@localhost:5432/edi_integration
SECRET_KEY=supersecretkey123

# ── Environment: "local" or "production" ──────────────────────────────────────
ENVIRONMENT=local

# ── Render Server (your cloud server with static IP) ──────────────────────────
# Update this once you deploy on Render
RENDER_URL=https://po-integration-backend.onrender.com

# ── Render Outbound IPs (give these to Blinkit for whitelisting) ──────────────
# 74.220.48.0/24
# 74.220.56.0/24

# ── Blinkit Integration ────────────────────────────────────────────────────────
BLINKIT_API_KEY=your_blinkit_api_key_here
BLINKIT_BASE_URL=https://api.blinkit.com

# ── Zepto Integration (Silk Route) ────────────────────────────────────────────
# Credentials shared by Zepto during onboarding
ZEPTO_CLIENT_ID=your_zepto_client_id_here
ZEPTO_CLIENT_SECRET=your_zepto_client_secret_here
# QA: https://silkroute.zeptonow.dev  |  Prod: https://silkroute.zepto.co.in
# Leave unset to auto-select based on ENVIRONMENT (local=QA, production=Prod)
ZEPTO_BASE_URL=

# ── Swiggy Integration ────────────────────────────────────────────────────────
SWIGGY_API_KEY=your_swiggy_api_key_here
SWIGGY_BASE_URL=https://api.swiggy.com
